# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# JWT
JWT_SECRET=your-jwt-secret-min-32-characters-long

# Tiny ERP OAuth2
TINY_ERP_CLIENT_ID=your-client-id
TINY_ERP_CLIENT_SECRET=your-client-secret
TINY_ERP_ACCESS_TOKEN=your-access-token
TINY_ERP_REFRESH_TOKEN=your-refresh-token
TINY_ERP_BASE_URL=https://api.tiny.com.br/api2

# Flask API
FLASK_API_URL=http://localhost:5000
FLASK_INTERNAL_API_KEY=your-shared-secret

# Webhook Security
WEBHOOK_SECRET=your-webhook-secret-token
